generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  USER
  ADMIN
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
}

enum Skill {
  LISTENING
  SPEAKING
  READING
  WRITING
  GRAMMAR
  VOCABULARY
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  REORDER_SENTENCE
  MATCHING
  LISTENING
  SPEAKING
  WRITING
}

enum LessonStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum PronunciationProvider {
  WEB_SPEECH
  MOCK
  AI
}

enum BadgeConditionType {
  FIRST_LESSON
  STREAK_DAYS
  TOTAL_XP
  FIRST_FLASHCARD_REVIEW
  PERFECT_LESSON
  LESSONS_COMPLETED
  EXERCISES_COMPLETED
}

// ============================================================
// MODELS
// ============================================================

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  fullName           String
  avatarUrl          String?
  role               Role      @default(USER)
  sourceLanguageCode String    @default("vi")
  targetLanguageCode String    @default("en")
  currentCefrLevel   CefrLevel @default(A1)
  xp                 Int       @default(0)
  streakCount        Int       @default(0)
  lastStudyDate      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  refreshTokens          RefreshToken[]
  placementTests         PlacementTest[]
  learningPaths          LearningPath[]
  lessonProgresses       LessonProgress[]
  exerciseAttempts       ExerciseAttempt[]
  flashcards             Flashcard[]
  flashcardReviews       FlashcardReview[]
  pronunciationAttempts  PronunciationAttempt[]
  userBadges             UserBadge[]
  xpTransactions         XpTransaction[]
  studySessions          StudySession[]

  @@map("users")
}

model Language {
  id                String   @id @default(uuid())
  code              String   @unique
  name              String
  nativeName        String
  isSourceSupported Boolean  @default(true)
  isTargetSupported Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@map("languages")
}

model PlacementTest {
  id                 String    @id @default(uuid())
  userId             String
  sourceLanguageCode String
  targetLanguageCode String    @default("en")
  resultLevel        CefrLevel?
  totalScore         Int?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("placement_tests")
}

model PlacementQuestion {
  id                 String  @id @default(uuid())
  level              CefrLevel
  questionText       String
  explanation        String?
  sourceLanguageCode String?
  options            Json
  correctAnswer      String
  skill              Skill
  createdAt          DateTime @default(now())

  @@map("placement_questions")
}

model LearningPath {
  id                 String    @id @default(uuid())
  userId             String
  targetLanguageCode String    @default("en")
  sourceLanguageCode String
  cefrLevel          CefrLevel
  title              String
  description        String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("learning_paths")
}

model Lesson {
  id                 String    @id @default(uuid())
  cefrLevel          CefrLevel
  targetLanguageCode String    @default("en")
  sourceLanguageCode String?
  title              String
  description        String?
  skill              Skill
  orderIndex         Int       @default(0)
  estimatedMinutes   Int       @default(15)
  xpReward           Int       @default(10)
  isPublished        Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  exercises        Exercise[]
  lessonProgresses LessonProgress[]

  @@map("lessons")
}

model Exercise {
  id                 String       @id @default(uuid())
  lessonId           String
  type               ExerciseType
  prompt             String
  instruction        String?
  sourceLanguageCode String?
  targetText         String?
  options            Json?
  correctAnswer      String
  explanation        String?
  difficulty         Int          @default(1)
  xpReward           Int          @default(5)
  orderIndex         Int          @default(0)

  lesson                Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exerciseAttempts      ExerciseAttempt[]
  pronunciationAttempts PronunciationAttempt[]

  @@map("exercises")
}

model LessonProgress {
  id          String       @id @default(uuid())
  userId      String
  lessonId    String
  status      LessonStatus @default(NOT_STARTED)
  score       Int?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progresses")
}

model ExerciseAttempt {
  id         String   @id @default(uuid())
  userId     String
  exerciseId String
  answer     String
  isCorrect  Boolean
  score      Int      @default(0)
  feedback   String?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_attempts")
}

model Vocabulary {
  id              String    @id @default(uuid())
  word            String
  ipa             String?
  audioUrl        String?
  cefrLevel       CefrLevel
  partOfSpeech    String?
  exampleSentence String?
  createdAt       DateTime  @default(now())

  translations VocabularyTranslation[]
  flashcards   Flashcard[]

  @@map("vocabularies")
}

model VocabularyTranslation {
  id                 String @id @default(uuid())
  vocabularyId       String
  languageCode       String
  meaning            String
  explanation        String?
  exampleTranslation String?

  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([vocabularyId, languageCode])
  @@map("vocabulary_translations")
}

model Flashcard {
  id                 String   @id @default(uuid())
  userId             String
  vocabularyId       String
  sourceLanguageCode String
  easeFactor         Float    @default(2.5)
  interval           Int      @default(0)
  repetition         Int      @default(0)
  dueDate            DateTime @default(now())
  lastReviewedAt     DateTime?
  createdAt          DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  reviews    FlashcardReview[]

  @@unique([userId, vocabularyId])
  @@map("flashcards")
}

model FlashcardReview {
  id            String   @id @default(uuid())
  flashcardId   String
  userId        String
  quality       Int      // 0-5 per SM-2
  oldInterval   Int
  newInterval   Int
  oldEaseFactor Float
  newEaseFactor Float
  reviewedAt    DateTime @default(now())

  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("flashcard_reviews")
}

model PronunciationAttempt {
  id                String                @id @default(uuid())
  userId            String
  exerciseId        String?
  targetText        String
  transcriptText    String?
  audioUrl          String?
  score             Int?
  wordLevelFeedback Json?
  provider          PronunciationProvider @default(WEB_SPEECH)
  createdAt         DateTime              @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  @@map("pronunciation_attempts")
}

model Badge {
  id             String             @id @default(uuid())
  code           String             @unique
  name           String
  description    String?
  iconUrl        String?
  conditionType  BadgeConditionType
  conditionValue Int                @default(1)

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model XpTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp_transactions")
}

model StudySession {
  id               String    @id @default(uuid())
  userId           String
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  durationSeconds  Int?
  xpEarned         Int       @default(0)
  lessonsCompleted Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_sessions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}